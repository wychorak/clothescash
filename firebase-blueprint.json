{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product listed on Vinted.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The ID of the user who owns this product."
        },
        "title": {
          "type": "string",
          "description": "The title of the product."
        },
        "description": {
          "type": "string",
          "description": "The description of the product."
        },
        "category": {
          "type": "string",
          "description": "The category of the product (e.g., shoes, hoodie)."
        },
        "brand": {
          "type": "string",
          "description": "The brand of the product."
        },
        "size": {
          "type": "string",
          "description": "The size of the product."
        },
        "purchasePrice": {
          "type": "number",
          "description": "The price the product was purchased for."
        },
        "isSold": {
          "type": "boolean",
          "description": "Whether the product has been sold."
        },
        "salePrice": {
          "type": "number",
          "description": "The price the product was sold for."
        },
        "purchaseDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date the product was purchased."
        },
        "saleDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date the product was sold."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date the product was added to the tracker."
        }
      },
      "required": ["uid", "title", "category", "purchasePrice", "isSold", "purchaseDate", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "The collection of products."
    }
  }
}
