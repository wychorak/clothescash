rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - immutable
    //   - title: string (required, max 100 chars)
    //   - description: string (optional, max 1000 chars)
    //   - category: string (required, max 50 chars)
    //   - brand: string (optional, max 50 chars)
    //   - size: string (optional, max 20 chars)
    //   - purchasePrice: number (required, >= 0)
    //   - isSold: boolean (required)
    //   - salePrice: number (optional, >= 0)
    //   - purchaseDate: timestamp (required)
    //   - saleDate: timestamp (optional)
    //   - createdAt: timestamp (required) - immutable
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }
    
    function isValidOptionalPositive(field) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is number && request.resource.data[field] >= 0);
    }
    
    function isValidTimestamp(field) {
      return request.resource.data[field] is timestamp;
    }
    
    function isValidOptionalTimestamp(field) {
      return !(field in request.resource.data) || request.resource.data[field] is timestamp;
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidProduct() {
      return hasRequiredFields(['uid', 'title', 'category', 'purchasePrice', 'isSold', 'purchaseDate', 'createdAt']) &&
             validStringLength('title', 1, 100) &&
             isValidOptionalString('description', 0, 1000) &&
             validStringLength('category', 1, 50) &&
             isValidOptionalString('brand', 0, 50) &&
             isValidOptionalString('size', 0, 20) &&
             isPositive('purchasePrice') &&
             request.resource.data.isSold is bool &&
             isValidOptionalPositive('salePrice') &&
             isValidTimestamp('purchaseDate') &&
             isValidOptionalTimestamp('saleDate') &&
             isValidTimestamp('createdAt');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
  }
}
